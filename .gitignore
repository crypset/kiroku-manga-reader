### Android ###

# Built application files
*.apk
*.ap_
*.aab

# ART/Dalvik VM files
*.dex

# Java/Kotlin class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
**/build/

# Local configuration (SDK path etc.)
local.properties

# Android Studio project files
.idea/
*.iml
*.ipr
*.iws
misc.xml
deploymentTargetDropDown.xml
render.experimental.xml

# Kotlin data
.kotlin/

# Captures (screenshots from device)
captures/

# Navigation editor temp files
.navigation/

# Keystore files (private signing keys — do NOT commit)
*.jks
*.keystore

# Google Services (if used)
google-services.json

# Firebase Crashlytics (temp files)
crashlytics-build.properties

# NDK
obj/

# Gradle wrapper logs
.gradle/
gradle-app.setting

# Cache
.cache/
*.lock
*.log

# OS-specific files
.DS_Store
Thumbs.db

# Jetifier
jetifier-standalone.log

# Lint
lint-intermediates/
lint-vitals/
lint-results.html
lint-results.xml

# Packaging files
*.zip
*.tar.gz
*.rar

# Virtual machine crash logs
hs_err_pid*
replay_pid*
