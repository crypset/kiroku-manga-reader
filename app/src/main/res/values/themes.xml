<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MangaReader" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/kiroku_primary</item>
        <item name="colorPrimaryVariant">@color/kiroku_background_deep</item>
        <item name="colorOnPrimary">@color/kiroku_on_primary</item>
        <item name="colorSecondary">@color/kiroku_secondary</item>
        <item name="colorSecondaryVariant">@color/kiroku_secondary_container</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/kiroku_surface</item>
        <item name="colorOnSurface">@color/kiroku_text_primary</item>
        <item name="android:statusBarColor">@color/kiroku_background_deep</item>
        <item name="android:navigationBarColor">@color/kiroku_background_deep</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowBackground">@color/kiroku_background</item>
        <item name="android:colorBackground">@color/kiroku_background</item>
        <item name="android:textColorPrimary">@color/kiroku_text_primary</item>
        <item name="android:textColorSecondary">@color/kiroku_text_secondary</item>
        <item name="materialButtonStyle">@style/Widget.Kiroku.Button</item>
    </style>

    <style name="Widget.Kiroku.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/kiroku_surface</item>
        <item name="titleTextColor">@color/kiroku_text_primary</item>
        <item name="subtitleTextColor">@color/kiroku_text_secondary</item>
        <item name="navigationIconTint">@color/kiroku_text_primary</item>
    </style>

    <style name="Widget.Kiroku.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">8dp</item>
        <item name="backgroundTint">@color/kiroku_primary</item>
        <item name="android:textColor">@color/kiroku_on_primary</item>
    </style>

    <style name="Theme.MangaReader.Reader" parent="Theme.MangaReader">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>
</resources>
